{
  "name": "checkmate-agent-system",
  "version": "0.1.0",
  "description": "Chess-governed multi-agent planning for Claude Code, Codex, npm/npx, and Python.",
  "type": "module",
  "bin": {
    "checkmate": "bin/checkmate.js",
    "checkmate-agent-system": "bin/checkmate.js"
  },
  "files": [
    "bin/",
    "checkmate/",
    "examples/basic_runtime.py",
    "lib/",
    "pyproject.toml",
    "scripts/",
    "skills/checkmate-agent-system/",
    "dist/checkmate-agent-system-skill.zip",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node scripts/run-node-tests.mjs && node scripts/run-python-tests.mjs",
    "doctor": "node bin/checkmate.js doctor",
    "pack:dry": "npm pack --dry-run",
    "plan": "node bin/checkmate.js plan --goal \"Build a migration plan\" --constraint \"must preserve uptime\"",
    "test": "npm run check",
    "build:zip": "node scripts/build-skill-zip.mjs",
    "prepack": "node scripts/build-skill-zip.mjs"
  },
  "exports": {
    ".": "./lib/index.js",
    "./plan": "./lib/plan.js",
    "./skill": "./lib/skill.js",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandosanti06/CheckMate.git"
  },
  "homepage": "https://github.com/mandosanti06/CheckMate#readme",
  "bugs": {
    "url": "https://github.com/mandosanti06/CheckMate/issues"
  },
  "author": "CheckMate contributors",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "ai-agents",
    "agent-framework",
    "codex",
    "claude",
    "claude-code",
    "python",
    "skills",
    "multi-agent",
    "orchestration",
    "planning",
    "prompt-engineering",
    "npx",
    "npm"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
